{
  "name": "unknown-diegesis",
  "version": "0.1.0",
  "description": "小说块编辑器 - Markdown+块编辑+双链",
  "main": "dist-electron/main.js",
  "homepage": "./",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "prepare": "husky"
  },
  "keywords": [
    "novel",
    "editor",
    "markdown",
    "block-editor",
    "electron",
    "react",
    "typescript"
  ],
  "author": "AnkoThread",
  "license": "MIT",
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.22",
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "vite-plugin-electron": "^0.28.1",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@tiptap/extension-blockquote": "^3.13.0",
    "@tiptap/extension-bullet-list": "^3.13.0",
    "@tiptap/extension-collaboration": "^3.13.0",
    "@tiptap/extension-color": "^3.20.1",
    "@tiptap/extension-drag-handle": "^3.13.0",
    "@tiptap/extension-heading": "^3.13.0",
    "@tiptap/extension-highlight": "^3.20.1",
    "@tiptap/extension-horizontal-rule": "^3.13.0",
    "@tiptap/extension-node-range": "^3.13.0",
    "@tiptap/extension-ordered-list": "^3.13.0",
    "@tiptap/extension-placeholder": "^3.13.0",
    "@tiptap/extension-task-item": "^3.13.0",
    "@tiptap/extension-task-list": "^3.13.0",
    "@tiptap/extension-text-style": "^3.20.1",
    "@tiptap/pm": "^3.13.0",
    "@tiptap/react": "^3.13.0",
    "@tiptap/starter-kit": "^3.13.0",
    "@tiptap/y-tiptap": "^3.0.1",
    "antd": "^6.3.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tiptap-markdown": "^0.9.0",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.20"
  },
  "packageManager": "yarn@4.12.0",
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,css,md,html,yml,yaml}": [
      "prettier --write"
    ]
  }
